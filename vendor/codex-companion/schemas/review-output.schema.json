{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Optional fields `class`, `authorization_relation`, `source_requirement`, `materiality`, `why_now`, `minimal_fix` are dev-orchestrator-internal extensions added on 2026-05-09 (Phase Ф6 of docs/plans/2026-05-08-review-loop-authorization.md). They MUST remain optional to keep upstream codex-companion adversarial-review.md output backward-compatible — upstream emits the original 8 required fields and nothing else, and any breakage on vendor sync should be detected by re-running the backward-compat fixtures from Phase Ф6 T6.4.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "findings",
    "next_steps"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "approve",
        "needs-attention"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "body",
          "file",
          "line_start",
          "line_end",
          "confidence",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_end": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "recommendation": {
            "type": "string"
          },
          "class": {
            "type": "string",
            "enum": [
              "MUST_FIX_NOW",
              "REGRESSION_FROM_AUTHORIZED_FIX",
              "DEFER",
              "NIT",
              "REJECTED_BY_SCOPE"
            ]
          },
          "authorization_relation": {
            "type": "string"
          },
          "source_requirement": {
            "type": "string"
          },
          "materiality": {
            "type": "string"
          },
          "why_now": {
            "type": "string"
          },
          "minimal_fix": {
            "type": "string"
          }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
